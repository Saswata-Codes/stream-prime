<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

  <uses-permission android:name="android.permission.FLASHLIGHT"/>
  <uses-permission android:name="android.permission.INTERNET"/>
  <uses-permission android:name="android.permission.RECORD_AUDIO"/>
  <uses-permission android:name="android.permission.CAMERA"/>
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

  <!--needed by background Rtp service to keep service alive-->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
  <!--Optional for play store-->
  <uses-feature android:name="android.hardware.camera" android:required="false" />
  <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
  <!--  Android 14 background compatibility-->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA"/>
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"/>

  <!--  This is only to allow compile extra-sources modules in app with min version 21. Never do it-->
  <uses-sdk tools:overrideLibrary="
  com.pedro.extrasources,
  com.serenegiant.uvccamera,
  androidx.core.ktx,androidx.core,
  androidx.annotation.experimental,
  androidx.media3.*,
  androidx.camera.*" />

  <application
      android:name=".App"
      android:label="@string/app_name"
      android:requestLegacyExternalStorage="true"
      android:usesCleartextTraffic="true"
      android:allowBackup="true"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:supportsRtl="true"
      android:theme="@style/Theme.RootEncoder"
      android:enableOnBackInvokedCallback="true"
      android:hardwareAccelerated="true"
      android:largeHeap="true"
      android:vmSafeMode="false"
      android:appComponentFactory="androidx.core.app.CoreComponentFactory"
      >
      
    <!-- Android 16 compatibility flags -->
    <meta-data
        android:name="android.max_aspect"
        android:value="2.4" />
    <meta-data
        android:name="android.app.lib_name"
        android:value="libstreamprime" />
    <meta-data
        android:name="android.app.extract_native_libs"
        android:value="true" />
    <meta-data
        android:name="android.app.uses_sdk"
        android:value="36" />
    <meta-data
        android:name="android.app.target_sdk"
        android:value="36" />
    <meta-data
        android:name="android.app.min_sdk"
        android:value="21" />
    <meta-data
        android:name="android.app.compatible_sdk"
        android:value="36" />
    <meta-data
        android:name="android.app.page_size_compatible"
        android:value="true" />

    <activity
        android:name="com.stream.prime.SplashActivity"
        android:label="@string/app_name"
        android:exported="true"
        android:screenOrientation="unspecified"
        android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
        android:theme="@style/Theme.RootEncoder.NoActionBar">
      <intent-filter>
        <action android:name="android.intent.action.VIEW"/>
        <action android:name="android.intent.action.MAIN"/>

        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
    </activity>

    <activity
        android:name="com.stream.prime.MainActivity"
        android:label="@string/app_name"
        android:exported="false"
        android:screenOrientation="unspecified"
        android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize" />

    <activity
        android:name=".settings.StreamSettingsActivity"
        android:exported="false"
        android:screenOrientation="unspecified"
        android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
        android:theme="@style/Theme.RootEncoder" />

    <activity
        android:name=".UnifiedStreamActivity"
        android:exported="false"
        android:screenOrientation="unspecified"
        android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
        android:theme="@style/Theme.RootEncoder" />

    <activity
        android:name=".overlay.LayerManagerActivity"
        android:exported="false"
        android:label="Overlay Library"
        android:theme="@style/Theme.RootEncoder" />

    <activity
        android:name=".overlay.OverlayStudioActivity"
        android:exported="false"
        android:label="Overlay Studio"
        android:theme="@style/Theme.RootEncoder" />

    <activity
        android:name=".FileStreamActivity"
        android:exported="false"
        android:theme="@style/Theme.RootEncoder" />

    <activity
        android:name=".file.FileStreamingActivity"
        android:exported="false"
        android:theme="@style/Theme.RootEncoder" />

    <activity android:name="com.stream.prime.rotation.RotationActivity"
        android:label="@string/rotation_rtmp"
        android:screenOrientation="fullSensor"
        android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
        android:minSdkVersion="21"
        tools:ignore="DiscouragedApi" />

    <service
        android:name=".screen.ScreenService"
        android:exported="false"
        android:foregroundServiceType="mediaProjection|microphone" />

    <service
        android:name=".file.FileStreamService"
        android:exported="false"
        android:foregroundServiceType="mediaProjection" />

    <!-- Accessibility Service for enhanced screen capture -->
    <service
        android:name=".accessibility.StreamAccessibilityService"
        android:exported="false"
        android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
        android:label="@string/accessibility_service_label">
        <intent-filter>
            <action android:name="android.accessibilityservice.AccessibilityService" />
        </intent-filter>
        <meta-data
            android:name="android.accessibilityservice"
            android:resource="@xml/accessibility_service_config" />
    </service>

    <service
        android:name=".FloatingOverlayService"
        android:exported="false" />

    <service
        android:name=".PersistentOverlayService"
        android:exported="false" />
  </application>

</manifest>
