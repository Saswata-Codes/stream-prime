<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/overlay_medium" />
            <corners android:radius="24dp" />
            <padding android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp" />
        </shape>
    </item>
    
    <!-- Inner shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/overlay_light" />
            <corners android:radius="24dp" />
            <padding android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp" />
        </shape>
    </item>
    
    <!-- Main glass card -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_background" />
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="@color/glass_border" />
        </shape>
    </item>
    
    <!-- Glass highlight -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/overlay_light"
                android:endColor="@color/transparent"
                android:angle="45" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list> 