<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/md_theme_surfaceVariant"
        android:endColor="@color/md_theme_surfaceVariant"
                android:angle="135" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Center preview icon -->
    <item android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/overlay_light" />
            <size android:width="80dp" android:height="80dp" />
        </shape>
    </item>
    
    <!-- Inner icon -->
    <item android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="@color/md_theme_primary" />
            <size android:width="60dp" android:height="60dp" />
        </shape>
    </item>
    
    <!-- Decorative elements -->
    <item android:gravity="top|start" android:left="20dp" android:top="20dp">
        <shape android:shape="oval">
            <solid android:color="@color/overlay_light" />
            <size android:width="8dp" android:height="8dp" />
        </shape>
    </item>
    
    <item android:gravity="top|end" android:right="20dp" android:top="20dp">
        <shape android:shape="oval">
            <solid android:color="@color/overlay_light" />
            <size android:width="8dp" android:height="8dp" />
        </shape>
    </item>
    
    <item android:gravity="bottom|start" android:left="20dp" android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="@color/overlay_light" />
            <size android:width="8dp" android:height="8dp" />
        </shape>
    </item>
    
    <item android:gravity="bottom|end" android:right="20dp" android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="@color/overlay_light" />
            <size android:width="8dp" android:height="8dp" />
        </shape>
    </item>
</layer-list> 