<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginBottom="12dp"
  android:background="@drawable/prism_overlay_background"
  android:orientation="vertical"
  android:padding="16dp">

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
    <TextView android:id="@+id/text_overlay_project_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="My Overlay" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
    <TextView android:id="@+id/text_overlay_project_live" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="#283C31" android:paddingHorizontal="10dp" android:paddingVertical="5dp" android:text="LIVE" android:textColor="#00E676" android:textSize="11sp" android:textStyle="bold" />
    <Switch android:id="@+id/switch_overlay_project_enabled" android:layout_width="wrap_content" android:layout_height="wrap_content" />
  </LinearLayout>

  <TextView android:id="@+id/text_overlay_project_summary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="0 images · 0 text" android:textColor="#AAB0BA" android:textSize="13sp" />

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="end">
    <Button android:id="@+id/btn_delete_overlay_project" style="?android:attr/buttonStyleSmall" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Delete" android:textAllCaps="false" />
    <Button android:id="@+id/btn_activate_overlay_project" style="?android:attr/buttonStyleSmall" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Use live" android:textAllCaps="false" />
    <Button android:id="@+id/btn_edit_overlay_project" style="?android:attr/buttonStyleSmall" android:layout_width="wrap_content" android:layout_height="40dp" android:text="Edit studio" android:textAllCaps="false" />
  </LinearLayout>
</LinearLayout>
