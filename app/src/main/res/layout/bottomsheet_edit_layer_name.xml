<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:padding="16dp"
  android:background="@color/prism_dark_surface">

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Edit Layer Name"
    android:textColor="@color/prism_text_primary"
    android:textSize="16sp"
    android:paddingBottom="8dp"/>

  <EditText
    android:id="@+id/input_layer_name"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:hint="Layer name"
    android:singleLine="true"
    android:padding="12dp"
    android:background="@drawable/prism_overlay_background"
    android:textColor="@color/prism_text_primary"
    android:textColorHint="#88FFFFFF"/>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:paddingTop="12dp">

    <TextView
      android:id="@+id/btn_cancel"
      android:layout_width="wrap_content"
      android:layout_height="40dp"
      android:paddingLeft="16dp"
      android:paddingRight="16dp"
      android:gravity="center"
      android:text="Cancel"
      android:textColor="@color/prism_text_primary"/>

    <View
      android:layout_width="12dp"
      android:layout_height="1dp"/>

    <TextView
      android:id="@+id/btn_ok"
      android:layout_width="wrap_content"
      android:layout_height="40dp"
      android:paddingLeft="16dp"
      android:paddingRight="16dp"
      android:gravity="center"
      android:text="OK"
      android:textColor="@color/prism_text_primary"
      android:background="@drawable/prism_circular_button"/>

  </LinearLayout>

</LinearLayout>


