<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginVertical="4dp"
  app:cardBackgroundColor="@color/prism_dark_surface"
  app:cardCornerRadius="8dp"
  app:cardElevation="2dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <View
      android:id="@+id/drag_handle"
      android:layout_width="24dp"
      android:layout_height="24dp"
      android:layout_marginEnd="12dp"
      android:background="@drawable/ic_drag_handle" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/text_layer_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Layer Name"
        android:textColor="@color/prism_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

      <Switch
        android:id="@+id/switch_layer_enabled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Enabled"
        android:textColor="@color/prism_text_secondary"
        android:textSize="12sp" />

    </LinearLayout>

    <TextView
      android:id="@+id/btn_edit_layer"
      android:layout_width="40dp"
      android:layout_height="40dp"
      android:layout_marginEnd="8dp"
      android:gravity="center"
      android:text="✎"
      android:textColor="@color/prism_neon_accent"
      android:textSize="18sp"
      android:background="@drawable/prism_circular_button"
      android:contentDescription="Edit Layer" />

    <TextView
      android:id="@+id/btn_delete_layer"
      android:layout_width="40dp"
      android:layout_height="40dp"
      android:gravity="center"
      android:text="🗑"
      android:textColor="@color/prism_neon_red"
      android:textSize="16sp"
      android:background="@drawable/prism_circular_button"
      android:contentDescription="Delete Layer" />

  </LinearLayout>

</androidx.cardview.widget.CardView>