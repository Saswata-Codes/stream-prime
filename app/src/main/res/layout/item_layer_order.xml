<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="54dp"
  android:layout_marginTop="6dp"
  android:background="#292C32"
  android:gravity="center_vertical"
  android:paddingStart="12dp"
  android:paddingEnd="6dp">

  <TextView
    android:id="@+id/text_layer_order_drag"
    android:layout_width="36dp"
    android:layout_height="match_parent"
    android:gravity="center"
    android:text="☰"
    android:textColor="#B8BDC7"
    android:textSize="20sp" />

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
      android:id="@+id/text_layer_order_name"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="#FFFFFF"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/text_layer_order_type"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textColor="#9EA4AF"
      android:textSize="11sp" />
  </LinearLayout>

  <Button
    android:id="@+id/btn_layer_order_lock"
    style="?android:attr/buttonStyleSmall"
    android:layout_width="72dp"
    android:layout_height="38dp"
    android:text="Lock"
    android:textAllCaps="false" />

  <Button
    android:id="@+id/btn_layer_order_delete"
    style="?android:attr/buttonStyleSmall"
    android:layout_width="68dp"
    android:layout_height="38dp"
    android:text="Delete"
    android:textColor="#FF6B6B"
    android:textAllCaps="false" />
</LinearLayout>
